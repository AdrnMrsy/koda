{
  "expo": {
    "name": "Koda",
    "slug": "koda",
    "version": "1.0.0",
    "scheme": "koda",
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#58CC02"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.belo.koda",
      "supportsTablet": true
    },
    "android": {
      "package": "com.belo.koda",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#58CC02"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b74a17c8-186d-4829-bc42-8dccdb92be5c"
      }
    }
  }
}